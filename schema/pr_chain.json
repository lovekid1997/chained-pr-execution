{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PR Chain Schema",
  "description": "Schema for validating PR chain structure",
  "type": "object",
  "required": ["issue_number", "prs"],
  "properties": {
    "issue_number": {
      "type": "integer",
      "description": "GitHub issue number"
    },
    "issue_title": {
      "type": "string",
      "description": "Issue title for reference"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "prs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/pr_node"
      }
    }
  },
  "definitions": {
    "pr_node": {
      "type": "object",
      "required": ["pr_number", "layer", "branch", "base_branch", "status"],
      "properties": {
        "pr_number": {
          "type": "integer",
          "description": "GitHub PR number"
        },
        "layer": {
          "type": "string",
          "enum": ["A", "B", "C", "A1", "A2", "B1", "B2", "C1", "C2"],
          "description": "Position in chain"
        },
        "branch": {
          "type": "string",
          "pattern": "^feat/[0-9]+-[a-z0-9-]+$",
          "description": "Branch name"
        },
        "base_branch": {
          "type": "string",
          "description": "Base branch (main or previous PR branch)"
        },
        "depends_on": {
          "type": ["integer", "null"],
          "description": "PR number this depends on"
        },
        "unblocks": {
          "type": ["integer", "null"],
          "description": "PR number this unblocks"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "open", "review", "approved", "merged", "closed"],
          "description": "Current PR status"
        },
        "title": {
          "type": "string",
          "description": "PR title"
        },
        "description": {
          "type": "string",
          "description": "Brief description of changes"
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "default": "low"
        },
        "key_files": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Critical files to review"
        },
        "merge_sha": {
          "type": ["string", "null"],
          "description": "Merge commit SHA after merged"
        }
      }
    }
  }
}
